# PixelRAG Docker Configuration
# Copy to .env and edit paths for your setup:
#   cp .env.example .env

# ─── Data Paths ────────────────────────────────────────────────────────────
# Where the pre-built FAISS index lives (downloaded from HuggingFace or built locally)
INDEX_DIR=./data/index

# Rendered screenshot tiles
TILES_DIR=./data/tiles

# Embeddings directory (intermediate, used during index build)
EMBEDDINGS_DIR=./data/embeddings

# Article metadata mapping (generated by `pixelrag index build`)
ARTICLES_JSON=./data/articles.json

# Input directory for rendering (PDFs, URLs lists, etc.)
INPUT_DIR=./data/input

# Pipeline config (for full index builds)
CONFIG_FILE=./pixelrag.yaml

# ─── Service Ports ─────────────────────────────────────────────────────────
HTTP_PORT=80
SERVE_PORT=30001
AGENT_PORT=30010

# ─── Search API (serve) ───────────────────────────────────────────────────
# Memory limit — the Wikipedia index is ~216GB. Set lower for smaller indexes.
SERVE_MEMORY_LIMIT=250g

# ─── Agent Configuration ──────────────────────────────────────────────────
# Budget cap per conversation (USD)
CHAT_MAX_BUDGET_USD=2.00

# Thinking tokens per turn
CHAT_THINKING_TOKENS=2000

# CORS allowed origin (set to your frontend domain in production)
ALLOWED_ORIGIN=https://pixelrag.ai

# Rate limiting
RL_PER_IP=12
RL_GLOBAL_DAILY=500
RL_MAX_CONCURRENT=3

# ─── Docker Image Registry (for CI/CD) ────────────────────────────────────
# Override to use a custom registry
REGISTRY=ghcr.io/startrail-org/pixelrag
IMAGE_TAG=latest
